{
  "manifest_version": 3,
  "name": "Detail Remover",
  "short_name": "Detail Remover",
  "description": "Detail Remover — removes div elements matching target selectors from any page.",
  "version": "1.0.0",
  "author": "anwarulmaarif",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["detail-remover.content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "detail-remover.icon.png",
    "48": "detail-remover.icon.png",
    "128": "detail-remover.icon.png"
  }
}
